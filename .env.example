# ProBooking environment template. Copy to .env and fill in. NEVER commit .env.
# Money is stored in integer satang; times stored UTC, displayed Asia/Bangkok (LOC-02).

# --- Core ---
NODE_ENV=development
TZ=UTC
DEFAULT_LOCALE=th-TH
SERVICE_FEE_BPS=1200            # 12% clinic-paid service fee (PAY-02). Basis points.

# --- Database (relational; Postgres) ---
DATABASE_URL=postgresql://probook:probook@localhost:5432/probook?schema=public

# --- Redis (optional; unused by the current polling worker) ---
# Reserved for a future durable queue (e.g. BullMQ) if polling outgrows a single worker.
# OTP rate state and throttle currently live in-process; Redis is not required for Phase 0/1.
# REDIS_URL=redis://localhost:6379

# --- API / Web ---
API_PORT=4000
WEB_PORT=3000
# Required for worker/API self-calls and static web builds outside a deliberately local-only deploy.
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# deploy-web.sh refuses to publish a localhost API base unless this is set for local-only builds.
# ALLOW_LOCAL_API_DEPLOY=1

# --- Worker ---
# How often the auto-accept sweep runs (CMP-03). Lower this in dev to see it fire.
AUTO_ACCEPT_SWEEP_MS=60000
# Worker requires JWT_SECRET and API_BASE_URL. For local/test only, this permits the worker
# to default API_BASE_URL to http://localhost:4000 when API_BASE_URL is unset.
# WORKER_ALLOW_DEFAULT_API=true

# --- Demo fixtures ---
# In-memory API: requires ALLOW_IN_MEMORY_STORE=true or AUTH_DEV_MODE=true when DATABASE_URL is unset.
# With Postgres: run `pnpm db:seed`, or set SEED_ON_BOOT=true to seed via Prisma on boot.
ALLOW_IN_MEMORY_STORE=true
SEED_ON_BOOT=

# --- Integrations (all abstracted behind ports; use sandbox creds in dev) ---
# Payment partner (durable Payment Protected prefunding; PAY-01)
PAYMENT_PROVIDER=mock
# Mock payments are refused when backed by a real database unless this explicit dev/test
# opt-in is set (never use with production payment flows).
# ALLOW_MOCK_PAYMENTS=true
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=
# SMS (offers near expiry, payment, confirmation, reminders; NOT-01)
SMS_PROVIDER=mock
SMS_API_KEY=
# Email (all critical events; NOT-01)
EMAIL_PROVIDER=mock
EMAIL_API_KEY=
# Identity / credential verification source (VER-01)
VERIFICATION_PROVIDER=manual
# Secure document storage (credentials, insurance evidence)
DOC_STORAGE_PROVIDER=local
DOC_STORAGE_BUCKET=probook-docs-dev

# --- Security ---
# Signing key for session tokens. MUST be set to a strong random value outside local dev
# (`openssl rand -hex 32`). The API refuses to boot without one unless AUTH_DEV_MODE=true
# under which it signs with an ephemeral per-process key instead of anything guessable.
JWT_SECRET=
OTP_PEPPER=change-me-in-dev-only

# Demo/dev mode: returns the OTP code in the /auth/otp/request response so sign-in needs no
# SMS partner. This lets a caller sign in as any phone that EXISTS, so only point it at a
# seeded, in-memory demo dataset (no DATABASE_URL) — never a real user database. Forced off
# when NODE_ENV=production. Safe to tunnel in that seeded-in-memory shape (see docs/deployment.md).
AUTH_DEV_MODE=true
# AUTH_DEV_MODE with DATABASE_URL is refused unless explicitly acknowledged for local/CI.
# This protects real databases from "sign in as any phone" dev behavior.
# ALLOW_DEV_AUTH_WITH_DATABASE=true

# Additionally enables POST /auth/dev/token, which mints an operations/finance/administrator
# token to ANY unauthenticated caller — a complete bypass with no phone needed. Decoupled from
# AUTH_DEV_MODE and OFF by default; the e2e suite is the only thing that needs it. NEVER set
# this on any host reachable from the internet, including a demo tunnel.
# DEV_TOKEN_ROUTE=true

# Encryption-at-rest key for sensitive columns (licence numbers, addresses, message
# bodies). 32 bytes hex — `openssl rand -hex 32`. Required outside local dev; under
# AUTH_DEV_MODE a fixed published dev key is used so dev data survives a restart.
FIELD_ENCRYPTION_KEY=

# Internal staff access list (§3): phone:role pairs resolved on OTP login.
# Empty by default in production — every OTP login is an ordinary user until you add entries.
# Local/demo default (matches playwright staff phones for ops/finance smoke):
#   STAFF_PHONES=+66900000008:operations,+66900000005:finance,+66900000006:finance,+66900000003:administrator
STAFF_PHONES=+66900000008:operations,+66900000005:finance,+66900000006:finance,+66900000003:administrator

# --- Rate limiting (§7.3) ---
# Fixed-window per IP+route. Defaults: 120/min overall, 10/min on the auth routes.
# Raise for a test/CI run rather than disabling, so a broken config still surfaces.
THROTTLE_LIMIT=
THROTTLE_AUTH_LIMIT=
THROTTLE_TTL_MS=
# Minimum ms between OTP requests for one phone (default 30000). Lower only for tests.
OTP_MIN_INTERVAL_MS=

# --- CORS ---
# Comma-separated allowlist of browser origins allowed to call the API.
# Required unless AUTH_DEV_MODE=true (which reflects any origin for convenience).
# For the Pages demo, lock it to the site origin — and include localhost if you also run
# the local web UI or the e2e suite, or the browser will block every call:
#   CORS_ORIGINS=https://tian-chaiyaporn2.github.io,http://localhost:3000
CORS_ORIGINS=
