{
  "name": "@probook/api",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS backend. Exposes controlled APIs; internal low-code Ops/Finance tools call these (ADM-02).",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check src",
    "test": "vitest run"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
