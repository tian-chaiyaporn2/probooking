{
  "name": "@probook/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "NestJS backend (ESM, tsc-built for decorator metadata). Exposes controlled APIs; internal low-code Ops/Finance tools call these (ADM-02).",
  "scripts": {
    "dev": "tsc --watch --preserveWatchOutput & node --watch --enable-source-maps dist/main.js",
    "build": "tsc",
    "start": "node --enable-source-maps dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check src",
    "test": "vitest run",
    "encrypt-pii": "node dist/scripts/encrypt-existing-pii.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@probook/db": "workspace:*",
    "@probook/domain": "workspace:*",
    "dotenv": "^16.4.5",
    "helmet": "^8.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.16.10",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
