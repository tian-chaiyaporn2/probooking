    "@nestjs/platform-express": "^10.4.4",
    "@probook/db": "workspace:*",
    "@probook/domain": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@types/express": "^5.0.0",
    "@types/node": "^20.16.10",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
